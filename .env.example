# Banco de dados MySQL
MYSQL_ROOT_PASSWORD=senha_root_aqui
MYSQL_DATABASE=pellissari_ausencias
MYSQL_USER=pellissari
MYSQL_PASSWORD=senha_db_aqui

# Flask
FLASK_SECRET_KEY=chave_secreta_longa_aleatoria_minimo_32_caracteres
FLASK_ENV=development

# E-mail SMTP
MAIL_SERVER=smtp.pellissari.com.br
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=sistema@pellissari.com.br
MAIL_PASSWORD=senha_email_aqui
MAIL_DEFAULT_SENDER=sistema@pellissari.com.br

# Conexão com o banco (usada pelo Flask)
# Em desenvolvimento, aponta para o container "db"
DATABASE_URL=mysql+pymysql://pellissari:senha_db_aqui@db:3306/pellissari_ausencias
